generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  password     String
  role         Role
  companyId    String?
  departmentId String?

  company      Company?    @relation(fields: [companyId], references: [id])
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  managedCompany Company?  @relation("CompanyManager")
  headedDepartment Department? @relation("DepartmentHead")

  assignedTasks Task[]     @relation("TaskAssignee")
  reports       Report[]

  @@index([companyId])
  @@index([departmentId])
}

model Company {
  id          String       @id @default(cuid())
  name        String
  managerId   String?      @unique
  manager     User?        @relation("CompanyManager", fields: [managerId], references: [id])
  departments Department[]
  users       User[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  companyId String
  headId    String?  @unique

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  head      User?    @relation("DepartmentHead", fields: [headId], references: [id])
  members   User[]   @relation("DepartmentMembers")
  tasks     Task[]

  @@index([companyId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String
  status       TaskStatus @default(TODO)
  assignedToId String
  departmentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedTo   User       @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  reports      Report[]

  @@index([assignedToId])
  @@index([departmentId])
}

model Report {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}
